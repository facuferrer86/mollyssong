# Copy to .env and fill in. Prisma's CLI reads .env (not .env.local), and
# Next.js reads .env too, so a single .env keeps DB + app config in one place.

# --- Database (Supabase Postgres — the single source of truth) ------------
# DATABASE_URL = POOLED connection (app/runtime): ...pooler.supabase.com:6543
#   /postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL   = session/direct connection (Prisma schema sync): ...:5432/postgres
# There is no local database — dev and prod both use Supabase.
DATABASE_URL=""
DIRECT_URL=""

# --- Supabase Storage (image hosting) -------------------------------------
# Project URL + service-role key from Supabase dashboard (Settings → API).
# SERVICE_ROLE is admin-grade: server-only, never expose as NEXT_PUBLIC_*.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
STORAGE_BUCKET="renders"

# --- Image generation -----------------------------------------------------
# Magnific (Freepik) API key: https://docs.magnific.com
MAGNIFIC_API_KEY=""

# --- Auth (Supabase magic link) -------------------------------------------
# Client-side auth uses the project URL + PUBLISHABLE (anon) key — safe to expose.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Only these emails may sign in (comma-separated). Empty = any authenticated user.
ALLOWED_EMAILS=""
