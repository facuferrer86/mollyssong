// Single source of truth for the Molly's Song hub data.
// `DATABASE_URL` is the pooled connection (used by the app); `DIRECT_URL` is the
// unpooled one Prisma uses for migrations. For local docker dev both can be the
// same direct URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Character {
  id        String         @id
  name      String
  color     String
  img       String
  role      String
  fields    Json // ordered label -> text map, edited as a blob in the UI
  prompt    String
  order     Int
  mapX      Float? // relationship-map node position (percent), null = auto-layout
  mapY      Float?
  gallery   GalleryImage[]
  positions BeatPosition[]
  relsFrom  Relationship[] @relation("RelFrom")
  relsTo    Relationship[] @relation("RelTo")
}

// A typed, directed relationship between two characters (the relationship web).
model Relationship {
  id     String    @id @default(cuid())
  fromId String
  toId   String
  from   Character @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Character @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)
  type   String    @default("") // ally/mentor/antagonist/family/love/rival/creator/other
  label  String    @default("")
  order  Int       @default(0)

  @@index([fromId])
  @@index([toId])
}

model GalleryImage {
  id          Int       @id @default(autoincrement())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  u           String
  l           String
  order       Int

  @@index([characterId])
}

model Zone {
  key   String @id
  label String
  x     Float
  y     Float
  w     Float
  h     Float
  order Int
}

model Beat {
  id           String         @id
  act          String
  title        String
  meta         String
  links        Json // array of [a,b] character-id pairs; never queried by element
  order        Int
  beatFunction String? // structural role from the active template, e.g. "Midpoint"
  positions    BeatPosition[]
}

// One character's placement in one beat. A relation (not a JSON blob on Beat) so
// a future editor can upsert a single placement and it joins to Character.
model BeatPosition {
  id          Int       @id @default(autoincrement())
  beatId      String
  beat        Beat      @relation(fields: [beatId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  zoneKey     String
  s           String

  @@unique([beatId, characterId])
}

model Location {
  id      String @id // == zone key
  name    String
  zoneKey String
  color   String
  summary String
  order   Int
  rooms   Room[]
}

model Room {
  pk         String      @id @default(cuid())
  id         String // client-facing slug, e.g. "main-lab" (unique within a location)
  locationId String
  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name       String
  lighting   String
  sounds     String
  ambient    String
  furniture  String
  map        String
  prompt     String
  order      Int
  images     RoomImage[]

  @@unique([locationId, id])
}

model RoomImage {
  id     String  @id // client-facing image id, e.g. "main-lab-abc123" or "atrium-base"
  roomPk String
  room   Room    @relation(fields: [roomPk], references: [pk], onDelete: Cascade)
  u      String // permanent public URL (Supabase Storage)
  l      String
  cam    Json? // { rotate, vertical, closeup } slider tuple
  base   Boolean @default(false)
  remote String? // public source URL for image-to-image reframes (== u once hosted)
  order  Int

  @@index([roomPk])
}

model Scene {
  id     String @id // "Act_I_Growing_Up/Scene_01_The_Lullaby.md"
  act    String // display, e.g. "Act I — Growing Up"
  actKey String // folder name, for canonical sort
  title  String
  slug   String // file name
  text   String
  order  Int
  shots  Shot[]

  @@unique([actKey, slug])
}

// A planned shot within a scene — the bridge from script to the AI generation
// queue. Carries the camera spec + a generated keyframe, and an opt-in flag to
// assemble the trailer shot list.
model Shot {
  pk           String  @id @default(cuid())
  sceneId      String
  scene        Scene   @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  order        Int
  title        String  @default("")
  description  String  @default("")
  shotSize     String  @default("") // EWS/WS/FS/MS/MCU/CU/ECU/Insert
  angle        String  @default("") // eye level/high/low/overhead/dutch/OTS/POV
  movement     String  @default("") // static/pan/tilt/dolly/tracking/crane/handheld/push/pull
  lens         String  @default("")
  lighting     String  @default("")
  durationSec  Float?
  prompt       String  @default("") // image-gen prompt for the keyframe
  imageUrl     String  @default("") // generated keyframe (Supabase Storage)
  clipUrl      String? // optional generated video clip
  notes        String  @default("")
  inTrailer    Boolean @default(false)
  trailerOrder Int?

  @@index([sceneId])
}

// Project-level story bible: a singleton row (id == "molly"). Holds the
// top-level canon — logline, theme, world rules, "the bible forbids" guardrails,
// and the active beat-structure template (Phase 3).
model Project {
  id                String  @id @default("molly")
  logline           String  @default("")
  theme             String  @default("")
  worldRules        Json    @default("[]") // string[]
  forbids           Json    @default("[]") // string[]
  structureTemplate String? // e.g. "save-the-cat" | "heros-journey" | "story-circle"
}
